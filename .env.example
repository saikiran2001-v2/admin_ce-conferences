# Environment variables for admin_ceconferences
# Copy this to .env and fill in real values

# Upstash Redis — must be the SAME instance as the main ceconferences site
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Admin credentials
ADMIN_PASSWORD=choose_a_strong_password_here
ADMIN_JWT_SECRET=choose_a_random_32plus_char_secret_here
